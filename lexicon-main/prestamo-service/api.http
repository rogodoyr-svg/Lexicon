@baseUrl = http://localhost:3334/api
@authUrl = {{baseUrl}}/auth
@prestamosUrl = {{baseUrl}}/prestamos

### =========================
### AUTH ENDPOINTS
### =========================

### Registrar un nuevo usuario
POST {{authUrl}}/register
Content-Type: application/json

{
  "username": "testuser",
  "password": "password123"
}

### Iniciar sesion
POST {{authUrl}}/login
Content-Type: application/json

{
  "username": "testuser",
  "password": "password123"
}

### Validar token JWT
GET {{authUrl}}/validate
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJ0ZXN0dXNlciIsImlhdCI6MTc3ODcxMDMzNiwiZXhwIjoxNzc4NzEzOTM2fQ.-v6kruFod6ovXqmGsa2zIbjItbYV9xHjvlJp6MVzuko

### =========================
### PRESTAMO-SERVICE ENDPOINTS
### =========================

### Obtener todos los prestamos
GET {{prestamosUrl}}
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJ0ZXN0dXNlciIsImlhdCI6MTc3ODcxMDMzNiwiZXhwIjoxNzc4NzEzOTM2fQ.-v6kruFod6ovXqmGsa2zIbjItbYV9xHjvlJp6MVzuko

### Obtener prestamos del usuario autenticado
GET {{prestamosUrl}}/usuario
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJ0ZXN0dXNlciIsImlhdCI6MTc3ODcxMDMzNiwiZXhwIjoxNzc4NzEzOTM2fQ.-v6kruFod6ovXqmGsa2zIbjItbYV9xHjvlJp6MVzuko

### Obtener prestamos por estado
GET {{prestamosUrl}}/estado?estado=ACTIVO
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJ0ZXN0dXNlciIsImlhdCI6MTc3ODcxMDMzNiwiZXhwIjoxNzc4NzEzOTM2fQ.-v6kruFod6ovXqmGsa2zIbjItbYV9xHjvlJp6MVzuko

### Obtener prestamo por ID
GET {{prestamosUrl}}/c0f8a7e1-5d3b-4a2f-8c9d-1e2f3a4b5c6d
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJ0ZXN0dXNlciIsImlhdCI6MTc3ODcxMDMzNiwiZXhwIjoxNzc4NzEzOTM2fQ.-v6kruFod6ovXqmGsa2zIbjItbYV9xHjvlJp6MVzuko

### Registrar un nuevo prestamo
POST {{prestamosUrl}}
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJ0ZXN0dXNlciIsImlhdCI6MTc3ODcxMDMzNiwiZXhwIjoxNzc4NzEzOTM2fQ.-v6kruFod6ovXqmGsa2zIbjItbYV9xHjvlJp6MVzuko

{
  "libroId": "c0f8a7e1-5d3b-4a2f-8c9d-1e2f3a4b5c6d"
}

### Devolver un libro
POST {{prestamosUrl}}/c0f8a7e1-5d3b-4a2f-8c9d-1e2f3a4b5c6d/devolucion
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJ0ZXN0dXNlciIsImlhdCI6MTc3ODcxMDMzNiwiZXhwIjoxNzc4NzEzOTM2fQ.-v6kruFod6ovXqmGsa2zIbjItbYV9xHjvlJp6MVzuko
