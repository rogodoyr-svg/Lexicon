
@baseUrl = http://localhost:3334/api
@authUrl = {{baseUrl}}/auth
@prestamosUrl = {{baseUrl}}/prestamos
@users = pedro

@prestamoId = ee2efb5d-5894-4781-b94c-e6343e88b379

### =========================
### AUTH ENDPOINTS
### =========================

### Registrar un nuevo usuario
POST {{authUrl}}/register
Content-Type: application/json

{
  "username": "pedro",
  "password": "pedro123"
}

### Iniciar sesion
POST {{authUrl}}/login
Content-Type: application/json

{
  "username": "pedro",
  "password": "pedro123"
}

### Validar token JWT
GET {{authUrl}}/validate
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJwZWRybyIsImlhdCI6MTc3OTkxNTM4MywiZXhwIjoxNzc5OTE4OTgzfQ.MDHPqSIzW4IfXdcobUuFG9ebQQtmUIQd2n15LKne5Uk

### Obtener todos los usuarios y sus tokens
GET {{authUrl}}/users
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJyb2RyaWdvIiwiaWF0IjoxNzc5NTc2Nzk0LCJleHAiOjE3Nzk1ODAzOTR9.IkUrgp1u0vkm9DT5cErYLqKRCVd8iGynmb50Vv_kg2A

### Eliminar un usuario
DELETE {{authUrl}}/users/rodrigo

### =========================
### PRESTAMO-SERVICE ENDPOINTS
### =========================

### Obtener todos los prestamos
GET {{prestamosUrl}} 
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJBeGVsIHJvc2UiLCJpYXQiOjE3Nzk5MTQzNDgsImV4cCI6MTc3OTkxNzk0OH0.LXafDsXcpmPKqJI7-FmVm0yjki8YFY9WxiUy_Fs36QM

### Obtener prestamos del usuario autenticado
GET {{prestamosUrl}}/usuario
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJyb2RyaWdvIiwiaWF0IjoxNzc5NTc2Nzk0LCJleHAiOjE3Nzk1ODAzOTR9.IkUrgp1u0vkm9DT5cErYLqKRCVd8iGynmb50Vv_kg2A

### Obtener prestamos por estado
GET {{prestamosUrl}}/estado?estado=ACTIVO
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJBeGVsIHJvc2UiLCJpYXQiOjE3Nzk5MTQ0NDEsImV4cCI6MTc3OTkxODA0MX0.UBUzkFrXMd8RW8kFVexTSNziV9KFjpdLOzwQX6IHQPs

### Obtener prestamo por ID
GET {{prestamosUrl}}/{{prestamoId}}
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJyb2RyaWdvIiwiaWF0IjoxNzc5NTc2Nzk0LCJleHAiOjE3Nzk1ODAzOTR9.IkUrgp1u0vkm9DT5cErYLqKRCVd8iGynmb50Vv_kg2A

